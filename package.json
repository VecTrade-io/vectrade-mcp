{
  "name": "@vectrade/mcp-server",
  "version": "1.1.0",
  "description": "VecTrade MCP Server — 27 financial tools for AI coding assistants",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vectrade-mcp-server": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "TOOLS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js --http",
    "start:sse": "node dist/index.js --sse",
    "test:claude-compat": "node scripts/claude-compat-check.mjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "finance",
    "stock",
    "trading",
    "ai",
    "vectrade",
    "claude",
    "cursor",
    "copilot"
  ],
  "author": "VecTrade <sdk@vectrade.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VecTrade-io/vectrade-mcp"
  },
  "homepage": "https://docs.vectrade.io/sdks/mcp",
  "bugs": {
    "url": "https://github.com/VecTrade-io/vectrade-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
